diff --git a/src/parser.mjs b/src/parser.mjs
index 4f47681..e4b309e 100644
--- a/src/parser.mjs
+++ b/src/parser.mjs
@@ -1,3 +1,24 @@
 export function parseList(line) {
-  return line.split(",").map((item) => item.trim()).filter(Boolean);
+  const items = [];
+  let current = "";
+  let inQuotes = false;
+
+  for (const char of line) {
+    if (char === '"') {
+      inQuotes = !inQuotes;
+      continue;
+    }
+
+    if (char === "," && !inQuotes) {
+      items.push(current);
+      current = "";
+      continue;
+    }
+
+    current += char;
+  }
+
+  items.push(current);
+
+  return items.map((item) => item.trim()).filter(Boolean);
 }
